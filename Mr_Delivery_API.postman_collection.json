{
	"info": {
		"_postman_id": "mr-delivery-api-collection",
		"name": "Mr Delivery API",
		"description": "مجموعة APIs لمشروع Mr Delivery - APIs للمحلات والمعارض",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
